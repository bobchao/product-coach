.DS_Store
.claude/settings.local.json
.claude/scheduled_tasks.lock
evals/runs/
evals/RESULTS*

# Product Coach memory: only *.md.example templates are tracked.
# Real memory files are per-user coaching data — never commit/PR them.
/memory/**/*.md

# Mounted skills: .claude/skills/ is a per-checkout mount point.
# What you mount is your own choice — never commit skill contents.
# Exception: pm-growth-coach is a first-party skill shipped with this repo.
/.claude/skills/*
!/.claude/skills/pm-growth-coach/

# Skill-compat scenario scripts are the product of "which candidate skills
# did you test" — per-scan artifacts, not shared harness infra. Keep the
# directory and the worked example, ignore anything else added locally.
/evals/fixtures/skill-compat/*
!/evals/fixtures/skill-compat/okr-intake.txt
